// 侧边栏天气卡片样式
.card-weather
  .weather-content
    padding: 0.3rem 0

  .weather-current
    text-align: center
    margin-bottom: 0.5rem

  .weather-city
    font-size: 0.85rem
    color: var(--font-color)
    opacity: 0.8

    i
      margin-right: 0.2rem

  .weather-main-row
    display: flex
    align-items: center
    justify-content: center
    gap: 0.5rem
    margin-top: 0.3rem

  .weather-icon-lg
    font-size: 2rem

  .weather-temp-lg
    font-size: 1.5rem
    font-weight: 600
    color: var(--text-highlight-color)

  .weather-desc
    font-size: 0.85rem
    color: var(--font-color)
    opacity: 0.8

  .weather-forecast-compact
    display: flex
    justify-content: space-between
    padding-top: 0.5rem
    border-top: 1px dashed var(--border-color)
    opacity: 0.9

  .weather-day
    display: flex
    flex-direction: column
    align-items: center
    gap: 0.2rem
    font-size: 0.75rem

  .day-name
    color: var(--font-color)
    opacity: 0.8

  .day-icon
    font-size: 1rem

  .day-temp
    color: var(--font-color)
    font-size: 0.7rem

  .weather-loading,
  .weather-error
    text-align: center
    padding: 0.5rem
    color: var(--font-color)
    opacity: 0.6
    font-size: 0.85rem

    i
      margin-right: 0.3rem
