// 万年历页面样式
#page .calendar-page .calendar-content
  padding: 1.5rem 2rem
  +maxMd()
    padding: 1rem

.calendar-header
  display: flex
  align-items: center
  justify-content: center
  gap: 1rem
  padding: 1rem 1.5rem
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 8px
  margin-bottom: 1rem
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5)

.cal-nav-btn, .cal-today-btn
  background: var(--bg-color)
  border: 1px solid var(--border-color)
  color: var(--font-color)
  cursor: pointer
  transition: all 0.2s

  &:hover
    background: var(--btn-hover-color)
    border-color: var(--btn-hover-color)
    color: #fff

.cal-nav-btn
  width: 36px
  height: 36px
  border-radius: 50%
  display: flex
  align-items: center
  justify-content: center

  i
    font-size: 1rem

.cal-today-btn
  padding: 0 12px
  height: 36px
  border-radius: 18px
  font-size: 0.85rem
  font-weight: 500

.calendar-main
  border: 1px solid var(--border-color)
  border-radius: 8px
  background: var(--card-bg)
  overflow: hidden
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5)

.calendar-weekdays
  display: grid
  grid-template-columns: repeat(7, 1fr)
  gap: 4px
  padding: 0.5rem
  background: var(--card-bg)
  border-bottom: 1px solid var(--border-color)

.weekday
  text-align: center
  font-size: 0.9rem
  font-weight: 600
  padding: 0.5rem 0
  color: var(--font-color)

.calendar-grid
  display: grid
  grid-template-columns: repeat(7, 1fr)
  gap: 4px
  padding: 0.5rem
  background: var(--card-bg)

.cal-day
  aspect-ratio: 1
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 4px
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  padding: 0.3rem
  cursor: pointer
  transition: all 0.2s
  position: relative
  min-height: 55px

  &:hover
    border-color: var(--text-hover)
    background: var(--text-bg-hover)

  &.empty
    background: transparent
    border: none
    cursor: default

  &.today
    background: #3b82f6
    border-color: #3b82f6

    .cal-day-num
      color: #fff
      font-weight: 600

    .cal-lunar, .cal-holiday-name, .cal-jieqi-name
      color: rgba(255, 255, 255, 0.9)

  &.weekend .cal-day-num
    color: #e74c3c

  &.selected
    border-color: var(--text-highlight-color)
    background: var(--text-bg-hover)
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.3)

.cal-day-num
  font-size: 1rem
  font-weight: 500
  color: #333
  line-height: 1.2

.cal-lunar, .cal-holiday-name, .cal-jieqi-name
  font-size: 0.65rem
  line-height: 1.2
  text-align: center
  max-width: 100%
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  margin-top: 2px

.cal-lunar
  color: var(--font-color)
  opacity: 0.7

.cal-holiday-name
  color: #f44336
  font-weight: 600

.cal-jieqi-name
  color: #10b981
  font-weight: 600

.cal-day.today
  .cal-holiday-name, .cal-jieqi-name
    font-weight: 700

.cal-day.today .cal-holiday-name
  color: #ffd700

.cal-day.today .cal-jieqi-name
  color: #a7f3d0

.cal-tag
  position: absolute
  top: 2px
  right: 2px
  font-size: 0.6rem
  font-weight: 600
  padding: 1px 4px
  border-radius: 3px
  line-height: 1.2
  z-index: 1

.cal-day.today .cal-tag
  background: rgba(255, 255, 255, 0.3)
  color: #fff

.cal-tag.tag-holiday
  background: #f44336
  color: #fff

.cal-tag.tag-workday
  background: #9e9e9e
  color: #fff

.calendar-detail
  margin-top: 1rem
  padding: 1.5rem
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 8px
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5)

.detail-header
  text-align: center
  margin-bottom: 1.5rem
  padding-bottom: 1rem
  border-bottom: 1px solid var(--border-color)

.detail-lunar-date
  font-size: 2rem
  font-weight: 600
  color: var(--text-highlight-color)
  line-height: 1.3

.detail-ganzhi
  font-size: 1rem
  color: var(--font-color)
  margin-top: 0.5rem

.detail-shengxiao
  display: inline-block
  margin-top: 0.5rem
  padding: 0.3rem 1rem
  background: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%)
  color: #8b4513
  font-weight: 600
  border-radius: 15px
  font-size: 0.85rem
  box-shadow: 0 2px 8px rgba(255, 140, 0, 0.3)

.detail-info
  display: grid
  grid-template-columns: repeat(3, 1fr)
  gap: 0.8rem
  margin-bottom: 1.2rem

.detail-row
  display: flex
  align-items: baseline
  gap: 0.4rem

.detail-label
  font-size: 0.85rem
  color: var(--font-color)
  opacity: 0.7
  white-space: nowrap

.detail-value
  font-size: 0.9rem
  color: var(--text-highlight-color)

  &.jieqi-value
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%)
    -webkit-background-clip: text
    -webkit-text-fill-color: transparent
    background-clip: text
    font-weight: 600
    font-size: 1rem

.detail-positions
  display: grid
  grid-template-columns: repeat(3, 1fr)
  gap: 0.8rem
  margin-bottom: 1.2rem
  padding: 1rem
  background: var(--bg-color)
  border-radius: 6px

.position-item
  text-align: center

.pos-label
  display: block
  font-size: 0.75rem
  color: var(--font-color)
  opacity: 0.7
  margin-bottom: 0.3rem

.pos-value
  font-size: 0.85rem
  color: var(--text-highlight-color)

.detail-bazi
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%)
  border-radius: 8px
  padding: 1rem
  margin-bottom: 1rem
  text-align: center

.bazi-title
  font-size: 0.8rem
  color: rgba(255, 255, 255, 0.6)
  margin-bottom: 0.5rem

.bazi-content
  font-size: 1.1rem
  color: #ffd700
  font-weight: 600
  letter-spacing: 2px
  margin-bottom: 0.3rem

.bazi-na-yin
  font-size: 0.8rem
  color: rgba(255, 255, 255, 0.7)

.detail-pengzu
  display: flex
  align-items: center
  justify-content: center
  gap: 0.5rem
  padding: 0.8rem
  background: var(--bg-color)
  border-radius: 6px
  margin-bottom: 1rem

  .detail-label
    font-size: 0.85rem
    color: var(--font-color)
    opacity: 0.7

  .detail-value
    font-size: 0.9rem
    color: #f59e0b

.detail-yi-ji
  display: grid
  grid-template-columns: 1fr 1fr
  gap: 1rem
  margin-bottom: 1.2rem

.yi-section, .ji-section
  padding: 0.8rem
  border-radius: 6px

.yi-section
  background: #f0fdf4
  border: 1px solid #bbf7d0

  .section-title
    color: #16a34a

.ji-section
  background: #fef2f2
  border: 1px solid #fecaca

  .section-title
    color: #dc2626

.section-title
  font-size: 0.85rem
  font-weight: 600
  margin-bottom: 0.5rem

.section-content
  font-size: 0.8rem
  color: var(--font-color)
  line-height: 1.6
  word-break: break-word

.detail-footer
  padding-top: 1rem
  border-top: 1px solid var(--border-color)

// 响应式
@media (max-width: 768px)
  .calendar-header
    gap: 0.5rem
    padding: 0.8rem

  .cal-nav-btn
    width: 32px
    height: 32px

    i
      font-size: 0.9rem

  .cal-today-btn
    padding: 0 8px
    height: 32px
    font-size: 0.75rem

  .calendar-main
    border-radius: 6px

  .calendar-weekdays, .calendar-grid
    padding: 0.3rem

  .calendar-grid
    gap: 2px

  .cal-day
    min-height: 45px
    border-radius: 4px
    padding: 0.2rem

  .cal-day-num
    font-size: 0.9rem

  .cal-lunar, .cal-holiday-name, .cal-jieqi-name
    font-size: 0.6rem

  .cal-tag
    font-size: 0.55rem
    padding: 1px 3px

  .calendar-detail
    padding: 1rem

  .detail-lunar-date
    font-size: 1.5rem

  .detail-info
    grid-template-columns: repeat(2, 1fr)

  .detail-positions
    grid-template-columns: repeat(2, 1fr)
    gap: 0.5rem

  .detail-yi-ji
    grid-template-columns: 1fr

  .section-content, .bazi-content
    font-size: 0.75rem

  .bazi-content
    letter-spacing: 1px
