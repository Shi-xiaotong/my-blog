// Calendar Page - Butterfly Theme Style

#page .calendar-page .calendar-content
  padding: 1.5rem 2rem
  background: var(--card-bg)
  border-radius: 12px
  border: 1px solid var(--border-color)
  box-shadow: var(--card-box-shadow)
  +maxMd()
    padding: 1rem
    border-radius: 12px

// Header navigation
.calendar-header
  display: flex
  align-items: center
  justify-content: center
  gap: 1rem
  padding: 1rem 1.5rem
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 12px
  margin-bottom: 1rem

.cal-nav-btn, .cal-today-btn
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  color: var(--font-color)
  cursor: pointer
  transition: all 0.25s ease

  &:hover
    border-color: var(--theme-color, #49b1f5)
    color: var(--theme-color, #49b1f5)

.cal-nav-btn
  width: 36px
  height: 36px
  border-radius: 50%
  display: flex
  align-items: center
  justify-content: center

  i
    font-size: 1rem

.cal-today-btn
  padding: 0 16px
  height: 36px
  border-radius: 18px
  font-size: 0.85rem
  font-weight: 500

// Calendar main area
.calendar-main
  border-radius: 12px
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  overflow: hidden

// Weekday headers
.calendar-weekdays
  display: grid
  grid-template-columns: repeat(7, 1fr)
  gap: 0
  padding: 0.8rem 0.5rem
  border-bottom: 1px solid var(--border-color)

.weekday
  text-align: center
  font-size: 0.85rem
  font-weight: 500
  padding: 0.5rem 0
  color: var(--font-color)
  opacity: 0.6

// Calendar grid
.calendar-grid
  display: grid
  grid-template-columns: repeat(7, 1fr)
  gap: 6px
  padding: 0.5rem
  background: transparent

// Day cells
.cal-day
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  padding: 0.6rem 0.3rem
  border-radius: 8px
  cursor: pointer
  transition: all 0.25s ease
  min-height: 48px

  &:hover
    background: var(--theme-color, #49b1f5)
    color: #fff

    .cal-day-num, .cal-day-lunar
      color: #fff

.cal-day-num
  font-size: 1rem
  font-weight: 500
  color: var(--font-color)

.cal-day-lunar
  font-size: 0.7rem
  color: var(--font-color)
  opacity: 0.5
  margin-top: 2px

.cal-day.today
  background: var(--theme-color, #49b1f5)
  color: #fff

  .cal-day-num, .cal-day-lunar
    color: #fff

.cal-day.other-month
  opacity: 0.3

// Calendar info section
.calendar-info
  margin-top: 1rem
  padding: 1rem
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 12px

.calendar-info-title
  font-size: 1.1rem
  font-weight: 600
  color: var(--font-color)
  margin-bottom: 0.5rem

.calendar-info-detail
  font-size: 0.85rem
  color: var(--font-color)
  opacity: 0.7
  line-height: 1.6

// Responsive
+maxMd()
  .calendar-header
    padding: 0.8rem 1rem
    gap: 0.5rem

  .cal-nav-btn
    width: 32px
    height: 32px

  .cal-today-btn
    padding: 0 12px
    height: 32px
    font-size: 0.8rem

  .calendar-grid
    gap: 4px
    padding: 0.3rem

  .cal-day
    padding: 0.4rem 0.2rem
    min-height: 40px
