// 万年历页面样式
#page
  .calendar-page
    .calendar-content
      padding: 1.5rem 2rem

      +maxMd()
        padding: 1rem

.calendar-header
  display: flex
  align-items: center
  justify-content: center
  gap: 1rem
  padding: 1rem 1.5rem
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 8px
  margin-bottom: 1rem
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5)

.cal-nav-btn
  background: var(--bg-color)
  border: 1px solid var(--border-color)
  color: var(--font-color)
  width: 36px
  height: 36px
  border-radius: 50%
  cursor: pointer
  display: flex
  align-items: center
  justify-content: center
  transition: all 0.2s

  &:hover
    background: var(--btn-hover-color)
    border-color: var(--btn-hover-color)
    color: #fff

  i
    font-size: 1rem

.cal-title
  display: flex
  flex-direction: column
  align-items: center
  min-width: 100px

.cal-year
  font-size: 1.3rem
  font-weight: 600
  color: var(--text-highlight-color)

.cal-month
  font-size: 0.9rem
  color: var(--font-color)

// 日历主体区域（包裹星期和日期格子）
.calendar-main
  border: 1px solid var(--border-color)
  border-radius: 8px
  background: var(--card-bg)
  overflow: hidden
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5)

.calendar-weekdays
  display: grid
  grid-template-columns: repeat(7, 1fr)
  gap: 4px
  padding: 0.5rem
  background: var(--card-bg)
  border-bottom: 1px solid var(--border-color)

.weekday
  text-align: center
  font-size: 0.9rem
  font-weight: 600
  padding: 0.5rem 0
  color: var(--font-color)

.calendar-grid
  display: grid
  grid-template-columns: repeat(7, 1fr)
  gap: 4px
  padding: 0.5rem
  background: var(--card-bg)

.cal-day
  aspect-ratio: 1
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 4px
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  padding: 0.3rem
  cursor: pointer
  transition: all 0.2s
  position: relative
  min-height: 55px

  &:hover
    border-color: var(--text-hover)
    background: var(--text-bg-hover)

  &.empty
    background: transparent
    border: none
    cursor: default

    &:hover
      background: transparent

  &.today
    background: #3b82f6
    border-color: #3b82f6

    .cal-day-num
      color: #fff
      font-weight: 600

    .cal-lunar
      color: rgba(255, 255, 255, 0.9)

  &.weekend
    .cal-day-num
      color: #e74c3c

  &.holiday
    background: #fff5f5
    border-color: #ffcdd9

    .cal-day-num
      color: #e74c3c

.cal-day-num
  font-size: 1rem
  font-weight: 500
  color: #333
  line-height: 1.2

.cal-lunar
  font-size: 0.7rem
  color: var(--font-color)
  opacity: 0.7
  line-height: 1.2
  text-align: center
  max-width: 100%
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  margin-top: 2px

// 休/调标签
.cal-tag
  font-size: 0.65rem
  font-weight: 500
  padding: 1px 5px
  border-radius: 3px
  margin-top: 2px
  line-height: 1.3

.cal-tag.tag-holiday
  background: #f44336
  color: #fff

.cal-tag.tag-workday
  background: #9e9e9e
  color: #fff

// 今天样式支持标签
.cal-day.today
  .cal-tag
    background: rgba(255, 255, 255, 0.3)
    color: #fff

  .cal-lunar
    color: rgba(255, 255, 255, 0.9)

.calendar-loading
  text-align: center
  padding: 3rem
  color: var(--font-color)
  font-size: 0.9rem

// 响应式
@media (max-width: 768px)
  .calendar-header
    gap: 0.5rem
    padding: 0.8rem

  .cal-nav-btn
    width: 32px
    height: 32px

    i
      font-size: 0.9rem

  .cal-year
    font-size: 1.1rem

  .cal-month
    font-size: 0.8rem

  .calendar-main
    border-radius: 6px

  .calendar-weekdays, .calendar-grid
    padding: 0.3rem

  .calendar-grid
    gap: 2px

  .cal-day
    min-height: 45px
    border-radius: 4px
    padding: 0.2rem

  .cal-day-num
    font-size: 0.9rem

  .cal-lunar
    font-size: 0.6rem

  .cal-tag
    font-size: 0.55rem
    padding: 1px 3px

// 选中日期样式
.cal-day.selected
  border-color: var(--text-highlight-color)
  background: var(--text-bg-hover)
  box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.3)

// 详情面板
.calendar-detail
  margin-top: 1rem
  padding: 1.5rem
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 8px
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5)

.detail-header
  text-align: center
  margin-bottom: 1.5rem
  padding-bottom: 1rem
  border-bottom: 1px solid var(--border-color)

.detail-lunar-date
  font-size: 2rem
  font-weight: 600
  color: var(--text-highlight-color)
  line-height: 1.3

.detail-ganzhi
  font-size: 1rem
  color: var(--font-color)
  margin-top: 0.5rem

.detail-shengxiao
  display: inline-block
  margin-top: 0.5rem
  padding: 0.3rem 1rem
  background: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%)
  color: #8b4513
  font-weight: 600
  border-radius: 20px
  font-size: 0.9rem
  box-shadow: 0 2px 8px rgba(255, 140, 0, 0.3)
  border-radius: 15px
  font-size: 0.85rem

.detail-info
  display: grid
  grid-template-columns: repeat(3, 1fr)
  gap: 0.8rem
  margin-bottom: 1.2rem

.detail-row
  display: flex
  align-items: baseline
  gap: 0.4rem

  &.full-width
    grid-column: 1 / -1

.detail-label
  font-size: 0.85rem
  color: var(--font-color)
  opacity: 0.7
  white-space: nowrap

.detail-value
  font-size: 0.9rem
  color: var(--text-highlight-color)

  &.jieqi-value
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%)
    -webkit-background-clip: text
    -webkit-text-fill-color: transparent
    background-clip: text
    font-weight: 600
    font-size: 1rem

// 方位信息
.detail-positions
  display: grid
  grid-template-columns: repeat(3, 1fr)
  gap: 0.8rem
  margin-bottom: 1.2rem
  padding: 1rem
  background: var(--bg-color)
  border-radius: 6px

.position-item
  text-align: center

.pos-label
  display: block
  font-size: 0.75rem
  color: var(--font-color)
  opacity: 0.7
  margin-bottom: 0.3rem

.pos-value
  font-size: 0.85rem
  color: var(--text-highlight-color)

// 八字区块
.detail-bazi
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%)
  border-radius: 8px
  padding: 1rem
  margin-bottom: 1rem
  text-align: center

.bazi-title
  font-size: 0.8rem
  color: rgba(255, 255, 255, 0.6)
  margin-bottom: 0.5rem

.bazi-content
  font-size: 1.1rem
  color: #ffd700
  font-weight: 600
  letter-spacing: 2px
  margin-bottom: 0.3rem

.bazi-na-yin
  font-size: 0.8rem
  color: rgba(255, 255, 255, 0.7)

// 彭祖百忌
.detail-pengzu
  display: flex
  align-items: center
  justify-content: center
  gap: 0.5rem
  padding: 0.8rem
  background: var(--bg-color)
  border-radius: 6px
  margin-bottom: 1rem

  .detail-label
    font-size: 0.85rem
    color: var(--font-color)
    opacity: 0.7

  .detail-value
    font-size: 0.9rem
    color: #f59e0b

// 宜忌
.detail-yi-ji
  display: grid
  grid-template-columns: 1fr 1fr
  gap: 1rem
  margin-bottom: 1.2rem

.yi-section, .ji-section
  padding: 0.8rem
  border-radius: 6px

.yi-section
  background: #f0fdf4
  border: 1px solid #bbf7d0

.ji-section
  background: #fef2f2
  border: 1px solid #fecaca

.section-title
  font-size: 0.85rem
  font-weight: 600
  margin-bottom: 0.5rem

.yi-section .section-title
  color: #16a34a

.ji-section .section-title
  color: #dc2626

.section-content
  font-size: 0.8rem
  color: var(--font-color)
  line-height: 1.6
  word-break: break-word

// 底部吉神凶煞
.detail-footer
  padding-top: 1rem
  border-top: 1px solid var(--border-color)

.detail-tags
  margin-top: 0.8rem
  display: flex
  gap: 0.5rem
  justify-content: center
  flex-wrap: wrap

.detail-jieqi, .detail-holiday
  display: inline-block
  padding: 0.25rem 0.8rem
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%)
  color: #fff
  border-radius: 20px
  font-size: 0.85rem
  font-weight: 500

.detail-holiday
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%)

// 响应式 - 详情面板
@media (max-width: 768px)
  .calendar-detail
    padding: 1rem

  .detail-lunar-date
    font-size: 1.5rem

  .detail-info
    grid-template-columns: repeat(2, 1fr)

  .detail-positions
    grid-template-columns: repeat(2, 1fr)
    gap: 0.5rem

  .detail-yi-ji
    grid-template-columns: 1fr

  .section-content
    font-size: 0.75rem

  .bazi-content
    font-size: 0.95rem
    letter-spacing: 1px
    font-size: 0.75rem
