// 万年历页面样式 - 主题适配风格

// 整体背景
#page .calendar-page .calendar-content
  padding: 1.5rem 2rem
  background: var(--card-bg)
  border-radius: 20px
  border: 1px solid var(--border-color)

// 头部导航
.calendar-header
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  gap: 1rem
  padding: 1rem 1.5rem
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 16px
  margin-bottom: 1rem

// 年月显示
.cal-current-date
  display: flex
  flex-direction: row
  gap: 0.5rem
  align-items: baseline

.cal-year
  font-size: 0.9rem
  color: var(--font-color)
  opacity: 0.7

.cal-month
  font-size: 1.4rem
  font-weight: 600
  color: var(--theme-color)

// 导航按钮行
.cal-nav-bar
  display: flex
  align-items: center
  justify-content: center
  gap: 0.5rem

.cal-nav-btn, .cal-today-btn
  background: transparent
  border: 1px solid var(--border-color)
  color: var(--font-color)
  cursor: pointer
  transition: all 0.25s ease

  &:hover
    background: var(--theme-color)
    border-color: var(--theme-color)
    color: #fff

.cal-nav-btn
  width: 36px
  height: 36px
  border-radius: 50%
  display: flex
  align-items: center
  justify-content: center

.cal-today-btn
  padding: 0 16px
  height: 36px
  border-radius: 18px
  font-size: 0.85rem
  font-weight: 500

// 主体日历
.calendar-main
  border-radius: 16px
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  overflow: hidden

// 星期标题
.calendar-weekdays
  display: grid
  grid-template-columns: repeat(7, 1fr)
  padding: 0.8rem 0.5rem
  border-bottom: 1px solid var(--border-color)

.weekday
  text-align: center
  font-size: 0.85rem
  font-weight: 500
  padding: 0.5rem 0
  color: var(--font-color)
  opacity: 0.8

// 日历网格
.calendar-grid
  display: grid
  grid-template-columns: repeat(7, 1fr)
  gap: 6px
  padding: 0.5rem

// 日期格子
.cal-day
  aspect-ratio: 1
  background: transparent
  border-radius: 10px
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  padding: 0.25rem
  cursor: pointer
  transition: all 0.2s ease
  position: relative
  min-height: 55px

  &:hover
    background: var(--light-grey)

  &.today
    background: var(--theme-color)

    .cal-day-num
      color: #fff
      font-weight: 600

    .cal-lunar, .cal-holiday-name, .cal-jieqi-name
      color: rgba(255, 255, 255, 0.9)

  &.weekend .cal-day-num
    color: var(--theme-color)

  &.selected:not(.today)
    background: var(--light-grey)
    box-shadow: 0 0 0 2px var(--border-color)

.cal-day-num
  font-size: 1rem
  font-weight: 500
  color: var(--font-color)

.cal-lunar, .cal-holiday-name, .cal-jieqi-name
  font-size: 0.65rem
  line-height: 1.2
  text-align: center
  max-width: 100%
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  margin-top: 2px
  color: var(--font-color)
  opacity: 0.8

.cal-holiday-name.important, .cal-jieqi-name
  color: var(--theme-color)
  font-weight: 500
  opacity: 1

.cal-tag
  position: absolute
  top: 3px
  right: 3px
  font-size: 0.55rem
  font-weight: 600
  padding: 1px 4px
  border-radius: 4px
  background: var(--theme-color)
  color: #fff

// ========== 详情区域 ==========

.calendar-detail
  margin-top: 1rem
  padding: 1.5rem
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 16px

// 头部 - 一行显示
.detail-header
  display: flex
  align-items: center
  justify-content: center
  gap: 1rem
  margin-bottom: 1.5rem
  padding-bottom: 1rem
  border-bottom: 1px solid var(--border-color)

.detail-lunar-date
  font-size: 1.8rem
  font-weight: 300
  color: var(--theme-color)

.detail-ganzhi
  font-size: 0.9rem
  color: var(--font-color)

.detail-shengxiao
  padding: 0.2rem 0.8rem
  border: 1.5px solid var(--theme-color)
  color: var(--theme-color)
  font-size: 0.8rem
  border-radius: 12px

// 基本信息 - flex 居中
.detail-info
  display: flex
  flex-wrap: wrap
  justify-content: center
  gap: 0.6rem
  margin-bottom: 1.2rem
  padding-bottom: 1rem
  border-bottom: 1px solid var(--border-color)

.detail-row
  display: flex
  align-items: center
  gap: 0.3rem
  padding: 0.4rem 0.8rem
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 6px

.detail-label
  font-size: 0.75rem
  color: var(--font-color)
  opacity: 0.6
  white-space: nowrap

.detail-value
  font-size: 0.8rem
  color: var(--font-color)

  &.jieqi-value
    color: var(--theme-color)
    font-weight: 600

// 八字
.detail-bazi
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 12px
  padding: 1rem
  margin-bottom: 1rem
  text-align: center

.bazi-title
  font-size: 0.8rem
  color: var(--font-color)
  opacity: 0.7
  margin-bottom: 0.5rem

.bazi-content
  font-size: 1.1rem
  color: var(--theme-color)
  font-weight: 500
  letter-spacing: 2px
  margin-bottom: 0.3rem

.bazi-na-yin
  font-size: 0.8rem
  color: var(--font-color)
  opacity: 0.8

// 方位
.detail-positions
  display: grid
  grid-template-columns: repeat(6, 1fr)
  gap: 0.5rem
  margin-bottom: 1rem
  padding: 0.8rem
  background: var(--card-bg)
  border-radius: 12px
  border: 1px solid var(--border-color)

.position-item
  text-align: center

.pos-label
  display: block
  font-size: 0.7rem
  color: var(--font-color)
  opacity: 0.7
  margin-bottom: 0.2rem

.pos-value
  font-size: 0.75rem
  color: var(--font-color)

// 彭祖百忌
.detail-pengzu
  display: flex
  align-items: center
  justify-content: center
  gap: 0.5rem
  padding: 0.6rem
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 8px
  margin-bottom: 1rem

// 宜忌
.detail-yi-ji
  display: grid
  grid-template-columns: 1fr 1fr
  gap: 0.8rem
  margin-bottom: 1rem

.yi-section, .ji-section
  padding: 0.6rem
  border-radius: 8px

.yi-section
  background: rgba(100, 200, 130, 0.1)
  border: 1px solid rgba(100, 200, 130, 0.2)

  .section-title
    color: #4ade80

.ji-section
  background: rgba(250, 120, 120, 0.1)
  border: 1px solid rgba(250, 120, 120, 0.2)

  .section-title
    color: #f87171

.section-title
  font-size: 0.8rem
  font-weight: 600
  margin-bottom: 0.3rem

.section-content
  font-size: 0.8rem
  color: var(--font-color)
  line-height: 1.5

// 吉凶神煞
.detail-footer
  padding-top: 1rem
  border-top: 1px solid var(--border-color)

// 响应式
@media (max-width: 768px)
  .calendar-header
    gap: 0.5rem
    padding: 0.8rem

  .cal-nav-btn
    width: 32px
    height: 32px

  .cal-today-btn
    padding: 0 12px
    height: 32px
    font-size: 0.75rem

  .calendar-grid
    gap: 4px
    padding: 0.3rem

  .cal-day
    min-height: 48px
    border-radius: 8px

  .cal-day-num
    font-size: 0.9rem

  .cal-lunar, .cal-jieqi-name
    display: none

  .calendar-detail
    padding: 1rem

  .detail-lunar-date
    font-size: 1.5rem

  .detail-positions
    grid-template-columns: repeat(3, 1fr)

  .detail-yi-ji
    grid-template-columns: 1fr

  .bazi-content
    font-size: 1rem
    letter-spacing: 1px
