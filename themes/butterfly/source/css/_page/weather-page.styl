// 天气页面样式 - Apple Weather 风格
.weather-page-content
  padding: 1rem 0

.weather-current-page
  text-align: center
  padding: 2rem 1.5rem
  background: linear-gradient(180deg, #183c4d 0%, #20485a 100%)
  border-radius: 20px
  color: #fff
  margin-bottom: 1.5rem
  position: relative
  overflow: hidden

.current-location
  font-size: 1.1rem
  color: rgba(255, 255, 255, 0.85)
  margin-bottom: 0.5rem

  i
    margin-right: 0.3rem

.current-main
  display: flex
  align-items: center
  justify-content: center
  gap: 0.5rem
  margin-bottom: 1.5rem

.current-icon-lg
  font-size: 3.5rem

.current-temp-lg
  font-size: 4.5rem
  font-weight: 200
  color: #fff
  letter-spacing: -3px

.current-desc
  font-size: 1.3rem
  color: rgba(255, 255, 255, 0.75)
  font-weight: 300

.current-details
  display: flex
  flex-wrap: wrap
  justify-content: center
  gap: 1rem
  margin-top: 1.5rem

.detail-row
  display: flex
  flex-direction: column
  align-items: center
  gap: 0.3rem
  padding: 1rem 1.2rem
  background: rgba(255, 255, 255, 0.1)
  border-radius: 12px
  min-width: 80px
  backdrop-filter: blur(10px)

.detail-label
  font-size: 0.75rem
  color: rgba(255, 255, 255, 0.5)
  text-transform: uppercase
  letter-spacing: 0.5px

.detail-value
  font-size: 1rem
  font-weight: 500
  color: rgba(255, 255, 255, 0.95)

.travel-advice
  margin-top: 1.5rem

.advice-section
  background: rgba(255, 255, 255, 0.08)
  backdrop-filter: blur(10px)
  border: 1px solid rgba(255, 255, 255, 0.1)
  border-radius: 16px
  padding: 1rem
  text-align: left

.advice-title
  font-size: 0.9rem
  font-weight: 600
  color: #f7c948
  margin-bottom: 0.8rem
  display: flex
  align-items: center
  gap: 0.4rem

  i
    font-size: 0.85rem

.advice-list
  display: flex
  flex-direction: column
  gap: 0.5rem

.advice-item
  display: flex
  align-items: flex-start
  gap: 0.6rem
  font-size: 0.85rem
  line-height: 1.5
  color: rgba(255, 255, 255, 0.85)

  i
    margin-top: 0.15rem
    color: rgba(255, 255, 255, 0.6)
    flex-shrink: 0

  span
    flex: 1

.weather-section
  margin-bottom: 1.5rem

.section-title
  font-size: 1rem
  font-weight: 600
  margin-bottom: 1rem
  padding-bottom: 0.5rem
  border-bottom: 2px solid var(--theme-color)
  color: var(--text-highlight-color)

  i
    margin-right: 0.3rem

.hourly-grid
  display: flex
  overflow-x: auto
  gap: 0.5rem
  padding: 0.5rem 0
  scrollbar-width: thin

  &::-webkit-scrollbar
    height: 6px

  &::-webkit-scrollbar-thumb
    background: var(--border-color)
    border-radius: 3px

.hourly-card
  display: flex
  flex-direction: column
  align-items: center
  gap: 0.4rem
  padding: 1rem 0.8rem
  background: var(--card-bg)
  border-radius: 12px
  min-width: 65px
  flex-shrink: 0
  border: 1px solid var(--border-color)

.hourly-time
  font-size: 0.75rem
  color: var(--font-color)
  opacity: 0.7

.hourly-icon
  font-size: 1.5rem

.hourly-temp
  font-size: 0.95rem
  font-weight: 600
  color: var(--text-highlight-color)

.hourly-pop
  font-size: 0.65rem
  color: #4facfe
  font-weight: 500

.daily-list
  display: flex
  flex-direction: column
  gap: 0.5rem

.daily-row
  display: flex
  align-items: center
  gap: 1rem
  padding: 1rem
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 12px
  transition: transform 0.2s

  &:hover
    transform: translateX(4px)

.daily-date-col
  display: flex
  flex-direction: column
  align-items: center
  min-width: 55px

.daily-day
  font-weight: 600
  color: var(--text-highlight-color)
  font-size: 0.95rem

.daily-date
  font-size: 0.7rem
  color: var(--font-color)
  opacity: 0.6

.daily-weather-col
  display: flex
  align-items: center
  gap: 0.5rem
  min-width: 90px

.daily-icon
  font-size: 1.4rem

.daily-text
  font-size: 0.85rem
  color: var(--font-color)

.daily-temp-col
  display: flex
  align-items: center
  gap: 0.5rem
  flex: 1
  min-width: 120px

.daily-temp
  font-size: 0.9rem
  font-weight: 600
  color: var(--text-highlight-color)
  min-width: 32px
  text-align: center

.daily-temp-bar
  flex: 1
  height: 4px
  background: linear-gradient(to right, #4facfe, #ff6b6b)
  border-radius: 2px
  position: relative

.daily-temp-fill
  position: absolute
  left: 0
  top: 0
  height: 100%
  background: rgba(255, 255, 255, 0.4)
  border-radius: 2px

.daily-info-col
  display: flex
  gap: 0.8rem
  font-size: 0.75rem
  color: var(--font-color)
  opacity: 0.75
  min-width: 200px
  justify-content: flex-end

.weather-error-page
  text-align: center
  padding: 3rem
  color: var(--font-color)

  i
    font-size: 3rem
    margin-bottom: 1rem
    display: block
    opacity: 0.5

  span
    display: block
    margin-bottom: 1rem
    opacity: 0.7

  button
    padding: 0.5rem 1.5rem
    background: var(--theme-color)
    color: #fff
    border: none
    border-radius: 8px
    cursor: pointer

    &:hover
      opacity: 0.9

// 响应式
@media (max-width: 768px)
  .weather-current-page
    padding: 1.5rem 1rem
    border-radius: 16px

  .current-main
    flex-direction: column
    gap: 0.3rem
    margin-bottom: 1.2rem

  .current-icon-lg
    font-size: 3rem

  .current-temp-lg
    font-size: 4rem
    letter-spacing: -2px

  .current-desc
    font-size: 1.1rem

  .current-details
    gap: 0.6rem

  .detail-row
    padding: 0.8rem 1rem
    min-width: 70px

  .detail-label
    font-size: 0.7rem

  .detail-value
    font-size: 0.9rem

  .advice-section
    padding: 0.8rem
    border-radius: 12px

  .advice-title
    font-size: 0.85rem

  .advice-item
    font-size: 0.8rem

  .advice-item:nth-child(n+3)
    display: none

  .daily-row
    flex-wrap: wrap
    padding: 0.8rem

  .daily-date-col
    min-width: 45px

  .daily-weather-col
    min-width: auto

  .daily-temp-col
    min-width: 100px
    order: 3
    width: 100%
    margin-top: 0.5rem
    padding-top: 0.5rem
    border-top: 1px dashed var(--border-color)

  .daily-info-col
    min-width: auto
    flex-wrap: wrap
    gap: 0.5rem
