// 天气页面样式
.weather-page-content {
  padding: 1rem 0;
}

.weather-current-page {
  text-align: center;
  padding: 1.5rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12px;
  color: #fff;
  margin-bottom: 1.5rem;
}

.current-location {
  font-size: 1.2rem;
  margin-bottom: 0.5rem;

  i {
    margin-right: 0.3rem;
  }
}

.current-main {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  margin-bottom: 1rem;
}

.current-icon-lg {
  font-size: 3rem;
}

.current-temp-lg {
  font-size: 3rem;
  font-weight: 600;
}

.current-desc {
  font-size: 1.2rem;
  opacity: 0.9;
}

.current-details {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(255, 255, 255, 0.3);
}

.detail-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
}

.detail-label {
  font-size: 0.75rem;
  opacity: 0.8;
}

.detail-value {
  font-size: 0.9rem;
  font-weight: 500;
}

.weather-section {
  margin-bottom: 1.5rem;
}

.section-title {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--theme-color);
  color: var(--text-highlight-color);

  i {
    margin-right: 0.3rem;
  }
}

.hourly-grid {
  display: flex;
  overflow-x: auto;
  gap: 0.5rem;
  padding: 0.5rem 0;
  scrollbar-width: thin;

  &::-webkit-scrollbar {
    height: 6px;
  }

  &::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 3px;
  }
}

.hourly-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.3rem;
  padding: 0.8rem;
  background: var(--card-bg);
  border-radius: 8px;
  min-width: 60px;
  flex-shrink: 0;
  border: 1px solid var(--border-color);
}

.hourly-time {
  font-size: 0.75rem;
  color: var(--font-color);
  opacity: 0.7;
}

.hourly-icon {
  font-size: 1.5rem;
}

.hourly-temp {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-highlight-color);
}

.hourly-pop {
  font-size: 0.65rem;
  color: #2196F3;
}

.daily-list {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.daily-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.8rem 1rem;
  background: var(--card-bg);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  transition: transform 0.2s, box-shadow 0.2s;

  &:hover {
    transform: translateX(4px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
}

.daily-date-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 60px;
}

.daily-day {
  font-weight: 600;
  color: var(--text-highlight-color);
  font-size: 0.95rem;
}

.daily-date {
  font-size: 0.7rem;
  color: var(--font-color);
  opacity: 0.6;
}

.daily-weather-col {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  min-width: 100px;
}

.daily-icon {
  font-size: 1.5rem;
}

.daily-text {
  font-size: 0.85rem;
  color: var(--font-color);
}

.daily-temp-col {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex: 1;
  min-width: 140px;
}

.daily-temp {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-highlight-color);
  min-width: 35px;
  text-align: center;
}

.daily-temp-bar {
  flex: 1;
  height: 6px;
  background: linear-gradient(to right, #4FC3F7, #FF7043);
  border-radius: 3px;
  position: relative;
}

.daily-temp-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 3px;
}

.daily-info-col {
  display: flex;
  gap: 0.8rem;
  font-size: 0.75rem;
  color: var(--font-color);
  opacity: 0.8;
  min-width: 280px;
  justify-content: flex-end;
}

.weather-error-page {
  text-align: center;
  padding: 3rem;
  color: var(--font-color);

  i {
    font-size: 3rem;
    margin-bottom: 1rem;
    display: block;
    opacity: 0.5;
  }

  span {
    display: block;
    margin-bottom: 1rem;
    opacity: 0.7;
  }

  button {
    padding: 0.5rem 1.5rem;
    background: var(--theme-color);
    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;

    &:hover {
      opacity: 0.9;
    }
  }
}

// 响应式
@media (max-width: 768px) {
  .current-main {
    flex-direction: column;
    gap: 0.3rem;
  }

  .current-icon-lg,
  .current-temp-lg {
    font-size: 2.5rem;
  }

  .current-details {
    gap: 0.5rem;
  }

  .detail-row {
    min-width: 50px;
  }

  .daily-row {
    flex-wrap: wrap;
    padding: 0.6rem;
  }

  .daily-date-col {
    min-width: 50px;
  }

  .daily-weather-col {
    min-width: auto;
  }

  .daily-temp-col {
    min-width: 100px;
    order: 3;
    width: 100%;
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--border-color);
  }

  .daily-info-col {
    min-width: auto;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
}
