// Weather Page - Butterfly Theme Style
.weather-page-content
  padding: 1rem 0

.weather-current-page
  text-align: center
  padding: 2rem 1.5rem
  background: var(--card-bg)
  border-radius: 12px
  color: var(--font-color)
  margin-bottom: 1.5rem
  border: 1px solid var(--border-color)
  box-shadow: var(--card-box-shadow)
  position: relative
  overflow: hidden

.current-location
  font-size: 1.1rem
  color: var(--font-color)
  opacity: 0.85
  margin-bottom: 0.5rem

  i
    margin-right: 0.3rem
    color: var(--theme-color, #49b1f5)

.current-main
  display: flex
  align-items: center
  justify-content: center
  gap: 0.5rem
  margin-bottom: 1.5rem

.current-icon-lg
  font-size: 3.5rem
  color: var(--theme-color, #49b1f5)

.current-temp-lg
  font-size: 4.5rem
  font-weight: 200
  color: var(--font-color)
  letter-spacing: -3px

.current-desc
  font-size: 1.3rem
  color: var(--font-color)
  opacity: 0.75
  font-weight: 300

.current-details
  display: flex
  flex-wrap: wrap
  justify-content: center
  gap: 1rem
  margin-top: 1.5rem

.detail-row
  display: flex
  flex-direction: column
  align-items: center
  gap: 0.3rem
  padding: 1rem 1.2rem
  background: var(--card-bg)
  border-radius: 12px
  min-width: 80px
  border: 1px solid var(--border-color)

.detail-label
  font-size: 0.75rem
  color: var(--font-color)
  opacity: 0.5
  text-transform: uppercase
  letter-spacing: 0.5px

.detail-value
  font-size: 1rem
  font-weight: 500
  color: var(--font-color)

.travel-advice
  margin-top: 1.5rem

.advice-section
  background: var(--card-bg)
  border: 1px solid var(--border-color)
  border-radius: 12px
  padding: 1rem
  text-align: left

.advice-title
  font-size: 0.9rem
  font-weight: 600
  color: var(--theme-color, #49b1f5)
  margin-bottom: 0.8rem
  display: flex
  align-items: center
  gap: 0.4rem

  i
    font-size: 0.85rem

.advice-list
  display: flex
  flex-direction: column
  gap: 0.5rem

.advice-item
  display: flex
  align-items: flex-start
  gap: 0.6rem
  font-size: 0.85rem
  line-height: 1.5
  color: var(--font-color)
  opacity: 0.85

  i
    margin-top: 0.15rem
    color: var(--theme-color, #49b1f5)
    flex-shrink: 0
