extends includes/layout.pug

block content
  #page
    article.card-widget
      .card-content
        style.
          .games-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
          .game-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; text-decoration: none; color: var(--text); transition: all var(--duration-fast) var(--ease-out); display: flex; gap: 16px; backdrop-filter: blur(8px); }
          .game-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-2px); border-color: var(--primary); }
          .game-thumb { width: 80px; height: 80px; border-radius: var(--radius-lg); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
          .game-thumb svg { width: 40px; height: 40px; }
          .game-meta h3 { font-size: 17px; margin-bottom: 4px; }
          .game-meta p { font-size: 13px; color: var(--text-secondary); line-height: 1.5; margin-bottom: 6px; }
          .game-tag { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; background: var(--primary-light); color: var(--primary); }
          .best-score { font-size: 12px; color: var(--warning); margin-top: 4px; }
          .games-page-header { text-align: center; padding: 20px 0 30px; }
          .games-page-header h1 { font-size: var(--text-3xl); margin-bottom: 8px; }
          .games-page-header p { color: var(--text-secondary); font-size: var(--text-lg); }
          @media (max-width: 640px) { .games-grid { grid-template-columns: 1fr; } .game-thumb { width: 60px; height: 60px; } .game-thumb svg { width: 30px; height: 30px; } }
        .games-page-header
          h1 小游戏
          p 经典小游戏合集，纯前端零依赖，即开即玩
        .games-grid#gamesGrid
        .footer: p 更多游戏开发中 · #[a(href="/") 233002.xyz]
      script.
        (function(){const games=[{id:'2048',name:'2048',desc:'滑动合并数字方块，挑战最高分',tag:'益智',scoreKey:'best_2048',color:'#f59e0b'},{id:'snake',name:'贪吃蛇',desc:'控制蛇吃食物，越长越难',tag:'经典',scoreKey:'best_snake',color:'#22c55e'},{id:'memory',name:'记忆翻牌',desc:'翻开卡牌找到所有配对',tag:'休闲',scoreKey:null,color:'#a855f7'},{id:'minesweeper',name:'扫雷',desc:'经典扫雷，三个难度可选',tag:'策略',scoreKey:'best_minesweeper',color:'#ef4444'},{id:'typing',name:'打字速度',desc:'测试你的打字速度和准确率',tag:'技能',scoreKey:'best_wpm',color:'#3b82f6'},{id:'tetris',name:'俄罗斯方块',desc:'经典方块消除，挑战极限',tag:'经典',scoreKey:'best_tetris',color:'#ec4899'},{id:'wordle',name:'Wordle',desc:'6次机会猜出5个字母的单词',tag:'益智',scoreKey:'best_wordle',color:'#538d4e'},{id:'sudoku',name:'数独',desc:'经典数字逻辑谜题',tag:'策略',scoreKey:null,color:'#0ea5e9'},{id:'flappy',name:'Flappy Bird',desc:'点击控制飞行，躲避障碍物',tag:'街机',scoreKey:'best_flappy',color:'#f97316'},{id:'life',name:'生命游戏',desc:'Conway元胞自动机，观察生命演化',tag:'模拟',scoreKey:null,color:'#8b5cf6'},{id:'pixel',name:'像素画板',desc:'绘制像素艺术，导出PNG图片',tag:'创作',scoreKey:null,color:'#0ea5e9'},{id:'tictactoe',name:'井字棋',desc:'人机对战，Minimax AI不可战胜',tag:'策略',scoreKey:null,color:'#10b981'},{id:'pinball',name:'弹球台',desc:'物理弹球，挡板击球得分',tag:'街机',scoreKey:'best_pinball',color:'#f97316'},{id:'gomoku',name:'五子棋',desc:'人机对战，启发式AI对手',tag:'策略',scoreKey:null,color:'#d97706'},{id:'ai-guess',name:'AI 猜图',desc:'AI生成图片，你猜描述词',tag:'AI',scoreKey:null,color:'#8b5cf6'},{id:'ai-draw',name:'AI 绘画猜谜',desc:'你画画，AI来猜是什么',tag:'AI',scoreKey:null,color:'#ec4899'},{id:'ai-20q',name:'AI 猜词',desc:'问是非题，猜出AI想的词',tag:'AI',scoreKey:null,color:'#0ea5e9'},{id:'ai-riddle',name:'AI 谜语',desc:'AI出谜语，你来猜答案',tag:'AI',scoreKey:null,color:'#f59e0b'},{id:'ai-story',name:'AI 故事接龙',desc:'和AI一起写故事，AI打分',tag:'AI',scoreKey:null,color:'#22c55e'},{id:'ai-turtle-soup',name:'AI 海龟汤',desc:'推理谜题，问是非题揭开真相',tag:'AI',scoreKey:null,color:'#8b5cf6'},{id:'ai-song',name:'AI 猜歌名',desc:'根据描述猜歌名，考验音乐知识',tag:'AI',scoreKey:null,color:'#f97316'},{id:'ai-poem-game',name:'AI 写诗对决',desc:'给关键词，AI写诗，你来评分',tag:'AI',