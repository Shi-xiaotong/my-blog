        const grid=document.getElementById('gamesGrid');
        grid.innerHTML=games.map(g=>{const best=g.scoreKey?localStorage.getItem(g.scoreKey):null;const bestHtml=best?`<div class="best-score">最高: ${best}</div>`:'';return`<a href="/games/${g.id}.html" class="game-card"><div class="game-thumb" style="background:${g.color}22;color:${g.color}">${icons[g.id]||''}</div><div class="game-meta"><h3>${g.name}</h3><p>${g.desc}</p><span class="game-tag">${g.tag}</span>${bestHtml}</div></a>`}).join('');})();