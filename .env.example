# === Cloudflare R2（hexo-cloudflare-r2-media 插件 + r2.js CLI）====
# 从 Cloudflare 面板获取（https://dash.cloudflare.com/?to=/:account/r2）
# 进入 myblog → 管理 R2 API 令牌 → 创建
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_ENDPOINT=https://32b5283fd99d2ea2abdc19507a5cf8d3.r2.cloudflarestorage.com
R2_BUCKET=myblog
R2_PUBLIC_URL=https://img.233002.xyz

# === Agnes AI API（daily-news.py 脚本） ===
AGNES_API_KEY=your_agnes_api_key

# === Cloudflare API（wrangler CLI） ===
CF_R2_TOKEN=your_cf_r2_token
CF_ACCOUNT_ID=your_cf_account_id