# === Cloudflare R2（hexo-cloudflare-r2-media 插件）====
# 删除 deploy.toml 的 Wrangler token（用于 pages deploy）

# === Hexo 构建（hexo-cloudflare-r2-media 插件） ===
# 从 _config.yml 移过来了，插件支持 process.env.* 自动读取
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key

# === Agnes AI API（daily-news.py 脚本） ===
AGNES_API_KEY=your_agnes_api_key

# === Cloudflare R2（daily-news.py 脚本） ===
CF_R2_TOKEN=your_cf_r2_token
CF_ACCOUNT_ID=your_cf_account_id
